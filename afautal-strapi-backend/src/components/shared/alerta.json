{
  "collectionName": "components_shared_alertas",
  "info": {
    "displayName": "Alerta",
    "icon": "exclamation-triangle",
    "description": "Caja de mensaje destacado (info, warning, success)"
  },
  "options": {},
  "attributes": {
    "tipo": {
      "type": "enumeration",
      "enum": [
        "info",
        "warning",
        "success",
        "error"
      ],
      "required": true,
      "default": "info"
    },
    "titulo": {
      "type": "string",
      "required": true
    },
    "mensaje": {
      "type": "text",
      "required": true
    }
  }
}
