{
  "kind": "collectionType",
  "collectionName": "solicitudes",
  "info": {
    "singularName": "solicitud",
    "pluralName": "solicitudes",
    "displayName": "Solicitud",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "rut": { "type": "string", "required": true, "unique": true, "maxLength": 9 },
    "nombre_completo": { "type": "string", "required": true },
    "fecha_nacimiento": { "type": "date", "required": true },
    "correo_electronico": { "type": "email", "required": true, "unique": true },
    "unidad_academica": { "type": "string" },
    "tipo_contrato": { "type": "enumeration", "enum": ["Planta regular"], "required": true },
    "jerarquia": { "type": "enumeration", "enum": ["Titular"], "required": true },
    "region": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::region.region"
    },
    "comuna": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::comuna.comuna"
    },
    "ciudad": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::ciudad.ciudad"
    },
    "direccion_particular": { "type": "string", "required": true },
    "telefono": { "type": "string" },
    "banco": { "type": "string" },
    "tipo_cuenta": {
      "type": "enumeration",
      "enum": ["Cuenta Corriente", "Cuenta Vista", "Cuenta RUT", "Cuenta de Ahorro"]
    },
    "estado": {
      "type": "enumeration",
      "enum": ["pendiente", "aprobado", "rechazado"],
      "default": "pendiente"
    },
    "acepta_descuento": { "type": "boolean", "required": true },
    "usuario": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "solicitud"
    }
  }
}