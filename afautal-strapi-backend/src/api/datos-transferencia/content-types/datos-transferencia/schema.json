{
  "kind": "singleType",
  "collectionName": "datos_transferencia",
  "info": {
    "singularName": "datos-transferencia",
    "pluralName": "datos-transferencias",
    "displayName": "Datos Transferencia",
    "description": "Datos bancarios oficiales de AFAUTAL para transferencias"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true,
      "default": "AFAUTAL"
    },
    "rut": {
      "type": "string",
      "required": true
    },
    "banco": {
      "type": "string",
      "required": true
    },
    "tipo_cuenta": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tipo-cuenta.tipo-cuenta"
    },
    "numero_cuenta": {
      "type": "string",
      "required": true
    },
    "correo_comprobante": {
      "type": "email",
      "required": true
    }
  }
}
