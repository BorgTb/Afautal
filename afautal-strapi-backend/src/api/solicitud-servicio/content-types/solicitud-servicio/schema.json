{
  "kind": "collectionType",
  "collectionName": "solicitudes_servicios",
  "info": {
    "singularName": "solicitud-servicio",
    "pluralName": "solicitudes-servicios",
    "displayName": "Solicitud de Servicio",
    "description": "Peticiones de horas para los distintos servicios"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "mensaje": {
      "type": "text",
      "required": true
    },
    "estado": {
      "type": "enumeration",
      "enum": ["pendiente", "agendada", "completada", "rechazada", "cancelada"],
      "default": "pendiente"
    },
    "usuario": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "solicitudes_servicios"
    },
    "carga_familiar": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::carga-familiar.carga-familiar"
    },
    "servicio": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::servicio.servicio"
    },
    "fecha_solicitud": {
      "type": "datetime"
    }
  }
}
