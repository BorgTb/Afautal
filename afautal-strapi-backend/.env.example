# --- Strapi Backend ENV (afautal-strapi-backend) ---
# Puerto del servidor
PORT=1337
HOST=0.0.0.0

# Secretos de la APP (Generar con: openssl rand -base64 32)
APP_KEYS=generar_key_1,generar_key_2
API_TOKEN_SALT=generar_salt
ADMIN_JWT_SECRET=generar_jwt_secret
TRANSFER_TOKEN_SALT=generar_transfer_salt

# Base de Datos (Para SQLite local)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Configuración de Previsualización y Seguridad (MUY IMPORTANTE EN PRODUCCIÓN)
# URL de tu frontend (ej: https://afautal.cl o http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# El mismo secreto que definas en el Frontend
PREVIEW_SECRET=tu-secreto-super-seguro

# (Opcional) Configuración de Email (SMTP/Resend/Sendgrid)
# EMAIL_PROVIDER=nodemailer
# EMAIL_SMTP_HOST=smtp.ejemplo.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=tu-usuario
# EMAIL_SMTP_PASS=tu-password
# EMAIL_DEFAULT_FROM=noreply@afautal.cl
